{
  "name": "cicd_seed_workflow",
  "description": "Primary seed workflow job",
  "path": "jobs",
  "maxConcurrentRuns": 1,
  "schedule": {
    "quartzCronExpression": "0 0 16 * * ?",
    "timezoneId": "UTC"
  },
  "parameters": [
    {
      "name": "job_param",
      "value": "seed_value"
    }
  ],
  "jobClusters": [
    {
      "clusterName": "cicd_seed_cluster",
      "newCluster": null
    }
  ],
  "tasks": [
    {
      "type": "NOTEBOOK_TASK",
      "taskKey": "prepare_dummy_data",
      "dependsOn": [],
      "runIf": "ALL_SUCCESS",
      "maxRetries": 0,
      "notebookPath": "__NOTEBOOK_PREPARE__",
      "cluster": {
        "clusterName": "cicd_seed_cluster",
        "newCluster": null
      },
      "parameters": []
    },
    {
      "type": "NOTEBOOK_TASK",
      "taskKey": "validate_dummy_data",
      "dependsOn": [
        {
          "taskKey": "prepare_dummy_data",
          "outcome": null
        }
      ],
      "runIf": "ALL_SUCCESS",
      "maxRetries": 0,
      "notebookPath": "__NOTEBOOK_VALIDATE__",
      "cluster": {
        "clusterName": "cicd_seed_cluster",
        "newCluster": null
      },
      "parameters": [
        {
          "name": "job_param",
          "value": "{{job.parameters.job_param}}"
        }
      ]
    }
  ]
}
